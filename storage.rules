rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Essay images: users can upload/read their own, admins can read all
    match /essays/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // 10MB limit
        && request.resource.contentType.matches('image/.*');
    }

    // Audio recordings: users can upload/read their own, admins can read all
    match /audio/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024  // 50MB limit
        && request.resource.contentType.matches('audio/.*');
    }

    // Documents (application docs): users can upload/read their own
    match /documents/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Admin check helper
    function isAdmin() {
      return request.auth.token.role in ['admin', 'teacher', 'superadmin'];
    }
  }
}
